{
  "name": "signalparse",
  "version": "0.1.0",
  "description": "High-performance, type-safe log analysis engine for detecting security threats in web server logs.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "signalparse": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "dev": "ts-node src/cli/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "security",
    "log-analysis",
    "siem",
    "regex",
    "threat-detection",
    "sqli",
    "xss",
    "apache",
    "nginx",
    "cli"
  ],
  "author": "Tevfik",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
